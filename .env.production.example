# Production Environment Variables
# Copy this file to .env.production and fill in your actual values
# DO NOT commit the actual .env.production file to GitHub

# ============================================
# Database Configuration
# ============================================
# MySQL connection string from PlanetScale
# Format: mysql://user:password@host/database
DATABASE_URL=mysql://your_user:your_password@your_host.mysql.database.azure.com/pdf_converter

# ============================================
# AWS S3 Configuration
# ============================================
# AWS credentials for file storage
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=pdf-to-word-converter-bucket

# ============================================
# Authentication & Security
# ============================================
# JWT secret for session signing (generate with: openssl rand -base64 32)
JWT_SECRET=your_random_jwt_secret_here

# OAuth configuration
VITE_APP_ID=your_oauth_app_id
OAUTH_SERVER_URL=https://api.manus.im
VITE_OAUTH_PORTAL_URL=https://auth.manus.im
OWNER_OPEN_ID=your_owner_open_id
OWNER_NAME=Your Name

# ============================================
# Manus API Configuration
# ============================================
# Built-in Forge API for LLM and other services
BUILT_IN_FORGE_API_URL=https://api.manus.im
BUILT_IN_FORGE_API_KEY=your_forge_api_key

# Frontend API access
VITE_FRONTEND_FORGE_API_KEY=your_frontend_forge_api_key
VITE_FRONTEND_FORGE_API_URL=https://api.manus.im

# ============================================
# Application Configuration
# ============================================
# Application title and branding
VITE_APP_TITLE=PDF to Word Converter
VITE_APP_LOGO=https://your-cdn.com/logo.png

# Node environment
NODE_ENV=production

# ============================================
# Optional: Analytics & Monitoring
# ============================================
# Analytics configuration (if using Manus analytics)
VITE_ANALYTICS_ENDPOINT=https://analytics.manus.im
VITE_ANALYTICS_WEBSITE_ID=your_website_id

# ============================================
# Optional: Error Tracking
# ============================================
# Sentry for error tracking
SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id

# ============================================
# Optional: Email Configuration
# ============================================
# For sending email notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@pdftoword.com

# ============================================
# Performance & Limits
# ============================================
# Maximum file size in MB
MAX_FILE_SIZE_MB=16

# Maximum processing time in seconds
MAX_PROCESSING_TIME_SECONDS=300

# Number of concurrent conversions allowed
MAX_CONCURRENT_CONVERSIONS=5

# ============================================
# Feature Flags
# ============================================
# Enable/disable features
ENABLE_BATCH_CONVERSION=true
ENABLE_EMAIL_NOTIFICATIONS=false
ENABLE_WEBHOOKS=false
ENABLE_ADMIN_DASHBOARD=false
